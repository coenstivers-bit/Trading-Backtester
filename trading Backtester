document.querySelectorAll('.chip').forEach(c=>c.addEventListener('click',()=>c.classList.toggle('selected')));
function handleFile(input){if(!input.files[0])return;const s=document.getElementById('upload-status');s.style.display='block';s.innerHTML=`✅ <span style="color:var(--accent)">${input.files[0].name}</span> — ${(input.files[0].size/1024).toFixed(1)} KB`;}

// ── GLOBALS ──────────────────────────────────────────────────────────────
let OHLCV=[],TRADES=[],eqData=[],ddData=[],moData=[];
let ind={ma9:true,ma21:true,bb:false,vol:true,rsi:true,macd:false,signals:true};
let vs=0,ve=0; // view start/end
let dragging=false,dragX=0,dragVS=0,hlTrade=null;
let eqChart=null;
const PAD={l:64,r:10,t:8,b:24};

// ── DATA GENERATORS ──────────────────────────────────────────────────────
function genOHLCV(days,base){
  const d=[];let p=base,v=base*1200,dt=new Date(2021,6,1);
  for(let i=0;i<days;i++){
    const ch=(Math.random()-.484)*.028;
    const o=p,c=p*(1+ch),h=Math.max(o,c)*(1+Math.random()*.014),l=Math.min(o,c)*(1-Math.random()*.014);
    const vol=v*(.6+Math.random()*.8);
    d.push({date:new Date(dt),open:o,high:h,low:l,close:c,volume:vol});
    p=c;v=v*.97+vol*.03;dt=new Date(dt);dt.setDate(dt.getDate()+1);
  }
  return d;
}
function calcMA(data,p){return data.map((_,i)=>i<p-1?null:data.slice(i-p+1,i+1).reduce((s,d)=>s+d.close,0)/p);}
function calcRSI(data,p){
  const r=new Array(data.length).fill(null);
  let g=0,l=0;
  for(let i=1;i<=p;i++){const d=data[i].close-data[i-1].close;if(d>0)g+=d;else l-=d;}
  let ag=g/p,al=l/p;
  r[p]=100-100/(1+ag/(al||.0001));
  for(let i=p+1;i<data.length;i++){const d=data[i].close-data[i-1].close;ag=(ag*(p-1)+(d>0?d:0))/p;al=(al*(p-1)+(d<0?-d:0))/p;r[i]=100-100/(1+ag/(al||.0001));}
  return r;
}
function calcMACD(data,f=12,s=26,sig=9){
  const ema=(arr,p)=>{const k=2/(p+1),r=new Array(arr.length).fill(null);let sum=0;for(let i=0;i<p;i++)sum+=arr[i].close;r[p-1]=sum/p;for(let i=p;i<arr.length;i++)r[i]=arr[i].close*k+r[i-1]*(1-k);return r;};
  const ef=ema(data,f),es=ema(data,s);
  const ml=data.map((_,i)=>ef[i]!=null&&es[i]!=null?ef[i]-es[i]:null);
  const sl=new Array(data.length).fill(null);
  let fi=ml.findIndex(v=>v!=null)+sig-1;
  if(fi<data.length){let sm=0;for(let i=fi-sig+1;i<=fi;i++)sm+=ml[i];sl[fi]=sm/sig;const k=2/(sig+1);for(let i=fi+1;i<data.length;i++)if(ml[i]!=null)sl[i]=ml[i]*k+sl[i-1]*(1-k);}
  const hist=data.map((_,i)=>ml[i]!=null&&sl[i]!=null?ml[i]-sl[i]:null);
  return{ml,sl,hist};
}
function calcBB(data,p=20,m=2){
  return data.map((_,i)=>{if(i<p-1)return null;const sl=data.slice(i-p+1,i+1).map(d=>d.close);const mn=sl.reduce((a,b)=>a+b,0)/p;const sd=Math.sqrt(sl.reduce((a,b)=>a+(b-mn)**2,0)/p);return{mid:mn,up:mn+m*sd,lo:mn-m*sd};});
}
function genTrades(ohlcv,ma9,ma21,count){
  const trades=[];let i=30;
  const mkts=[['BTC/USD','crypto'],['ETH/USD','crypto'],['SPX','indices'],['NQ100','indices'],['ES1!','futures'],['GC1!','futures'],['SOL/USD','crypto']];
  while(trades.length<count&&i<ohlcv.length-15){
    if(ma9[i]!=null&&ma21[i]!=null&&ma9[i-1]!=null&&ma21[i-1]!=null){
      const cu=ma9[i-1]<=ma21[i-1]&&ma9[i]>ma21[i];
      const cd=ma9[i-1]>=ma21[i-1]&&ma9[i]<ma21[i];
      if(cu||cd){
        const dir=cu?'long':'short',ep=ohlcv[i].close;
        const xi=Math.min(i+5+Math.floor(Math.random()*25),ohlcv.length-1);
        const xp=ohlcv[xi].close;
        const pct=(dir==='long'?(xp-ep)/ep:(ep-xp)/ep)*100;
        const sz=4000+Math.random()*12000,pnl=sz*pct/100;
        const [mkt,mt]=mkts[Math.floor(Math.random()*mkts.length)];
        trades.push({id:trades.length+1,ei:i,xi,ep,xp,dir,pct,sz,pnl,mkt,mt,ed:ohlcv[i].date,xd:ohlcv[xi].date});
        i=xi+2;continue;
      }
    }
    i++;
  }
  return trades;
}
function genEquity(cap,ret,len){
  const pts=[];let v=cap;const tr=ret/len;const d=new Date(2021,6,1);
  for(let i=0;i<len;i+=2){v+=v*(tr/100+(Math.random()-.47)*.007);const dt=new Date(d);dt.setDate(dt.getDate()+i);pts.push({x:dt.toLocaleDateString('en-US',{month:'short',year:'2-digit'}),y:Math.round(v)});}
  return pts;
}
function genDD(eq){let pk=0;return eq.map(p=>{if(p.y>pk)pk=p.y;return{x:p.x,y:pk>0?+((p.y-pk)/pk*100).toFixed(2):0};});}
function genMonthly(){
  const ms=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],out=[];
  ['2021','2022','2023','2024'].forEach(yr=>ms.slice(0,yr==='2024'?6:12).forEach(m=>out.push({x:`${m} ${yr}`,y:+(Math.random()*13-3.5).toFixed(2)})));
  return out;
}

// ── BACKTEST ─────────────────────────────────────────────────────────────
function runBacktest(){
  const btn=document.getElementById('run-btn');
  btn.classList.add('running');btn.textContent='⏳ Running...';
  document.getElementById('empty-state').style.display='none';
  document.getElementById('results-section').classList.remove('visible');
  const pw=document.getElementById('progress-wrap'),pb=document.getElementById('progress-bar'),
    ps=document.getElementById('progress-status'),pp=document.getElementById('progress-pct'),
    pl=document.getElementById('progress-log');
  pw.classList.add('visible');pb.style.width='0%';pl.innerHTML='';
  const steps=[[8,'ok','Loading OHLCV data...'],[18,'ok','Parsing strategy parameters...'],[30,'warn','Computing MA9, MA21...'],[44,'ok','Computing RSI(14)...'],[56,'ok','Computing MACD(12,26,9)...'],[68,'ok','Computing Bollinger Bands(20)...'],[80,'ok','Generating entry/exit signals...'],[92,'ok','Simulating trade execution...'],[100,'ok','✓ Backtest complete!']];
  let i=0;
  const itv=setInterval(()=>{
    if(i>=steps.length){clearInterval(itv);buildResults();return;}
    const[pct,cls,msg]=steps[i++];
    pb.style.width=pct+'%';pp.textContent=pct+'%';ps.textContent=msg;
    const ln=document.createElement('div');ln.className=`log-line ${cls}`;
    ln.textContent=`[${new Date().toLocaleTimeString()}] ${msg}`;
    pl.appendChild(ln);pl.scrollTop=pl.scrollHeight;
  },240);
}

function buildResults(){
  const btn=document.getElementById('run-btn');
  btn.classList.remove('running');btn.innerHTML='▶ Run Backtest';
  document.getElementById('progress-wrap').classList.remove('visible');

  const sel=document.querySelector('.chip.selected');
  const asset=sel?sel.dataset.val:'BTC/USD';
  const base=asset.includes('BTC')?28000:asset.includes('ETH')?1800:asset.includes('SOL')?80:asset.includes('SPX')?4000:asset.includes('NQ')?12000:asset.includes('GC')?1900:75;
  OHLCV=genOHLCV(365*3+180,base);
  OHLCV._ma9=calcMA(OHLCV,9);OHLCV._ma21=calcMA(OHLCV,21);
  OHLCV._rsi=calcRSI(OHLCV,14);OHLCV._macd=calcMACD(OHLCV);OHLCV._bb=calcBB(OHLCV);
  const cnt=Math.floor(Math.random()*55+35);
  TRADES=genTrades(OHLCV,OHLCV._ma9,OHLCV._ma21,cnt);

  const cap=100000,ret=+(Math.random()*55+15).toFixed(2),fe=cap*(1+ret/100);
  const sharpe=+(Math.random()*1.4+0.9).toFixed(2),dd=-(Math.random()*13+5).toFixed(2);
  const wins=TRADES.filter(t=>t.pnl>0).length,wr=(wins/TRADES.length*100).toFixed(1);
  const pf=+(Math.random()*.9+1.2).toFixed(2),avg=((fe-cap)/TRADES.length).toFixed(0);
  const bh=(Math.random()*35+8).toFixed(2),ls=TRADES.filter(t=>t.dir==='long').length;

  document.getElementById('m-return').textContent=`+${ret}%`;
  document.getElementById('m-rsub').textContent=`vs +${bh}% buy & hold`;
  document.getElementById('m-sharpe').textContent=sharpe;
  document.getElementById('m-dd').textContent=`${dd}%`;
  document.getElementById('m-wr').textContent=`${wr}%`;
  document.getElementById('m-wrsub').textContent=`${wins}/${TRADES.length} trades`;
  document.getElementById('m-pf').textContent=pf;
  document.getElementById('m-avg').textContent=`+$${avg}`;
  document.getElementById('m-trades').textContent=TRADES.length;
  document.getElementById('m-tsub').textContent=`${ls} long / ${TRADES.length-ls} short`;
  document.getElementById('m-equity').textContent=`$${Math.round(fe).toLocaleString()}`;
  document.getElementById('chart-title').textContent=`${asset} — Candlestick Chart`;

  vs=0;ve=Math.min(140,OHLCV.length);
  document.getElementById('results-section').classList.add('visible');
  setTimeout(()=>{
    resizeAll();renderChart();
    eqData=genEquity(cap,ret,OHLCV.length);ddData=genDD(eqData);moData=genMonthly();
    drawEQ('equity');buildTable();
    setupEvents();
  },60);
}

// ── CANVAS RENDER ─────────────────────────────────────────────────────────
function resizeAll(){
  const W=document.getElementById('chart-con').clientWidth;
  const sh=370,vh=ind.vol?75:0,rh=ind.rsi?100:0,mh=ind.macd?100:0;
  const setC=(id,h)=>{const c=document.getElementById(id);c.style.display=h>0?'block':'none';c.width=W;c.height=h;};
  setC('stock-canvas',sh);setC('vol-canvas',vh);setC('rsi-canvas',rh);setC('macd-canvas',mh);
}

function xS(i,n,W){return PAD.l+(i/(n-1||1))*(W-PAD.l-PAD.r);}

function renderChart(){
  if(!OHLCV.length)return;
  resizeAll();
  const sl=OHLCV.slice(vs,ve);
  drawStock(sl,OHLCV._ma9.slice(vs,ve),OHLCV._ma21.slice(vs,ve),OHLCV._bb.slice(vs,ve));
  if(ind.vol)drawVol(sl);
  if(ind.rsi)drawRSI(OHLCV._rsi.slice(vs,ve));
  if(ind.macd)drawMACD({ml:OHLCV._macd.ml.slice(vs,ve),sl:OHLCV._macd.sl.slice(vs,ve),hist:OHLCV._macd.hist.slice(vs,ve)});
  const sl0=sl[0],sln=sl[sl.length-1];
  if(sl0)document.getElementById('range-label').textContent=`${fmtD(sl0.date)} → ${fmtD(sln.date)}`;
}

function drawStock(sl,ma9,ma21,bb){
  const c=document.getElementById('stock-canvas'),ctx=c.getContext('2d'),W=c.width,H=c.height,n=sl.length;
  ctx.clearRect(0,0,W,H);
  if(!n)return;
  let mn=Math.min(...sl.map(d=>d.low))*.997,mx=Math.max(...sl.map(d=>d.high))*1.003;
  if(ind.bb)bb.forEach(b=>{if(b){mn=Math.min(mn,b.lo*.997);mx=Math.max(mx,b.up*1.003);}});
  const yS=v=>PAD.t+(1-(v-mn)/(mx-mn))*(H-PAD.t-PAD.b);
  const cw=Math.max(1.5,(W-PAD.l-PAD.r)/n*.7);

  // grid
  ctx.lineWidth=1;
  for(let g=0;g<=5;g++){
    const yv=mn+(mx-mn)*g/5,yp=yS(yv);
    ctx.strokeStyle='#1e2d3d';ctx.beginPath();ctx.moveTo(PAD.l,yp);ctx.lineTo(W-PAD.r,yp);ctx.stroke();
    ctx.fillStyle='#4a6b82';ctx.font='9px JetBrains Mono';ctx.textAlign='right';
    ctx.fillText(yv>9999?yv.toFixed(0):yv>99?yv.toFixed(1):yv.toFixed(2),PAD.l-4,yp+3);
  }
  // x labels
  ctx.fillStyle='#4a6b82';ctx.font='9px JetBrains Mono';ctx.textAlign='center';
  const ls=Math.max(1,Math.floor(n/7));
  sl.forEach((d,i)=>{if(i%ls===0)ctx.fillText(fmtD(d.date),xS(i,n,W),H-6);});

  // BB
  if(ind.bb){
    ctx.save();
    ctx.beginPath();let st=false;
    bb.forEach((b,i)=>{if(!b)return;const x=xS(i,n,W);if(!st){ctx.moveTo(x,yS(b.up));st=true;}else ctx.lineTo(x,yS(b.up));});
    for(let i=bb.length-1;i>=0;i--){const b=bb[i];if(!b)continue;ctx.lineTo(xS(i,n,W),yS(b.lo));}
    ctx.closePath();ctx.fillStyle='rgba(199,125,255,.06)';ctx.fill();
    ['up','mid','lo'].forEach(k=>{
      ctx.beginPath();st=false;
      bb.forEach((b,i)=>{if(!b)return;const x=xS(i,n,W),y=yS(b[k]);if(!st){ctx.moveTo(x,y);st=true;}else ctx.lineTo(x,y);});
      ctx.strokeStyle=k==='mid'?'rgba(199,125,255,.45)':'rgba(199,125,255,.8)';ctx.lineWidth=k==='mid'?1:1.5;
      ctx.setLineDash(k==='mid'?[4,3]:[]);ctx.stroke();ctx.setLineDash([]);
    });
    ctx.restore();
  }

  // MAs
  const drawLine=(vals,col)=>{ctx.beginPath();let s=false;vals.forEach((v,i)=>{if(v==null)return;const x=xS(i,n,W),y=yS(v);if(!s){ctx.moveTo(x,y);s=true;}else ctx.lineTo(x,y);});ctx.strokeStyle=col;ctx.lineWidth=1.5;ctx.stroke();};
  if(ind.ma9)drawLine(ma9,'#00e5ff');
  if(ind.ma21)drawLine(ma21,'#f5c842');

  // Trade signals
  if(ind.signals){
    TRADES.filter(t=>t.ei>=vs&&t.ei<ve).forEach(t=>{
      const li=t.ei-vs,xi=t.xi-vs,isL=t.dir==='long',hi=hlTrade&&hlTrade.id===t.id;
      if(li<0||li>=n)return;
      const x=xS(li,n,W),ye=yS(t.ep);
      ctx.save();
      ctx.fillStyle=isL?'#00e396':'#ff4560';ctx.shadowColor=ctx.fillStyle;ctx.shadowBlur=hi?18:7;
      ctx.beginPath();
      if(isL){ctx.moveTo(x,ye+2);ctx.lineTo(x-7,ye+18);ctx.lineTo(x+7,ye+18);}
      else{ctx.moveTo(x,ye-2);ctx.lineTo(x-7,ye-18);ctx.lineTo(x+7,ye-18);}
      ctx.closePath();ctx.fill();
      // Exit X
      if(xi>=0&&xi<n){
        const xx=xS(xi,n,W),yx=yS(t.xp);
        ctx.strokeStyle=t.pnl>=0?'#00e396':'#ff4560';ctx.lineWidth=hi?3:1.8;
        ctx.shadowColor=ctx.strokeStyle;ctx.shadowBlur=hi?12:4;
        ctx.beginPath();ctx.moveTo(xx-5,yx-5);ctx.lineTo(xx+5,yx+5);ctx.moveTo(xx+5,yx-5);ctx.lineTo(xx-5,yx+5);ctx.stroke();
        ctx.strokeStyle=t.pnl>=0?'rgba(0,227,150,.25)':'rgba(255,69,96,.25)';ctx.lineWidth=1;ctx.setLineDash([3,3]);
        ctx.beginPath();ctx.moveTo(x,ye);ctx.lineTo(xx,yx);ctx.stroke();ctx.setLineDash([]);
      }
      // Label
      ctx.shadowBlur=0;ctx.fillStyle=isL?'#00e396':'#ff4560';ctx.font='bold 7px JetBrains Mono';ctx.textAlign='center';
      ctx.fillText(isL?'L':'S',x,isL?ye+30:ye-23);
      ctx.restore();
    });
  }

  // Candles
  sl.forEach((d,i)=>{
    const x=xS(i,n,W),isU=d.close>=d.open,col=isU?'#00e396':'#ff4560';
    const bt=yS(Math.max(d.open,d.close)),bb2=yS(Math.min(d.open,d.close)),bh=Math.max(1,bb2-bt);
    ctx.strokeStyle=col;ctx.lineWidth=.9;
    ctx.beginPath();ctx.moveTo(x,yS(d.high));ctx.lineTo(x,bt);ctx.moveTo(x,bb2);ctx.lineTo(x,yS(d.low));ctx.stroke();
    ctx.fillStyle=isU?'rgba(0,227,150,.82)':'rgba(255,69,96,.82)';
    ctx.fillRect(x-cw/2,bt,cw,bh);
    if(bh>2){ctx.strokeStyle=col;ctx.lineWidth=.5;ctx.strokeRect(x-cw/2,bt,cw,bh);}
  });
}

function drawVol(sl){
  const c=document.getElementById('vol-canvas'),ctx=c.getContext('2d'),W=c.width,H=c.height,n=sl.length;
  ctx.clearRect(0,0,W,H);
  const maxV=Math.max(...sl.map(d=>d.volume));
  const cw=Math.max(1,(W-PAD.l-PAD.r)/n*.7);
  ctx.strokeStyle='#1e2d3d';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(PAD.l,0);ctx.lineTo(W-PAD.r,0);ctx.stroke();
  ctx.fillStyle='#4a6b82';ctx.font='9px JetBrains Mono';ctx.textAlign='left';ctx.fillText('VOLUME',PAD.l+4,12);
  sl.forEach((d,i)=>{const x=xS(i,n,W),h=(d.volume/maxV)*(H-18);ctx.fillStyle=d.close>=d.open?'rgba(0,227,150,.4)':'rgba(255,69,96,.4)';ctx.fillRect(x-cw/2,H-h,cw,h);});
}

function drawRSI(rsi){
  const c=document.getElementById('rsi-canvas'),ctx=c.getContext('2d'),W=c.width,H=c.height,n=rsi.length;
  ctx.clearRect(0,0,W,H);
  const yS=v=>6+(1-v/100)*(H-16);
  ctx.fillStyle='rgba(255,69,96,.06)';ctx.fillRect(PAD.l,yS(70),W-PAD.l-PAD.r,yS(100)-yS(70));
  ctx.fillStyle='rgba(0,227,150,.06)';ctx.fillRect(PAD.l,yS(30),W-PAD.l-PAD.r,yS(0)-yS(30));
  [[70,'#ff456050'],[50,'#1e2d3d'],[30,'#00e39650']].forEach(([v,col])=>{
    const y=yS(v);ctx.strokeStyle=col;ctx.lineWidth=1;ctx.setLineDash([3,3]);
    ctx.beginPath();ctx.moveTo(PAD.l,y);ctx.lineTo(W-PAD.r,y);ctx.stroke();ctx.setLineDash([]);
    ctx.fillStyle='#4a6b82';ctx.font='8px JetBrains Mono';ctx.textAlign='right';ctx.fillText(v,PAD.l-3,y+3);
  });
  ctx.beginPath();let s=false;
  rsi.forEach((v,i)=>{if(v==null)return;const x=xS(i,n,W),y=yS(v);if(!s){ctx.moveTo(x,y);s=true;}else ctx.lineTo(x,y);});
  ctx.strokeStyle='#c77dff';ctx.lineWidth=1.5;ctx.stroke();
  ctx.fillStyle='#4a6b82';ctx.font='9px JetBrains Mono';ctx.textAlign='left';ctx.fillText('RSI(14)',PAD.l+4,13);
}

function drawMACD(m){
  const c=document.getElementById('macd-canvas'),ctx=c.getContext('2d'),W=c.width,H=c.height,n=m.hist.length;
  ctx.clearRect(0,0,W,H);
  const vals=[...m.ml,...m.sl,...m.hist].filter(v=>v!=null);if(!vals.length)return;
  const mn=Math.min(...vals)*1.1,mx=Math.max(...vals)*1.1;
  const yS=v=>10+(1-(v-mn)/(mx-mn))*(H-20),yz=yS(0);
  const cw=Math.max(1,(W-PAD.l-PAD.r)/n*.6);
  ctx.strokeStyle='#1e2d3d';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(PAD.l,yz);ctx.lineTo(W-PAD.r,yz);ctx.stroke();
  m.hist.forEach((v,i)=>{if(v==null)return;const x=xS(i,n,W),y=yS(v);ctx.fillStyle=v>=0?'rgba(0,227,150,.5)':'rgba(255,69,96,.5)';ctx.fillRect(x-cw/2,Math.min(y,yz),cw,Math.abs(y-yz));});
  const dl=(vals,col)=>{ctx.beginPath();let s=false;vals.forEach((v,i)=>{if(v==null)return;const x=xS(i,n,W),y=yS(v);if(!s){ctx.moveTo(x,y);s=true;}else ctx.lineTo(x,y);});ctx.strokeStyle=col;ctx.lineWidth=1.5;ctx.stroke();};
  dl(m.ml,'#00e5ff');dl(m.sl,'#f5c842');
  ctx.fillStyle='#4a6b82';ctx.font='9px JetBrains Mono';ctx.textAlign='left';ctx.fillText('MACD(12,26,9)',PAD.l+4,13);
}

// ── EVENTS ───────────────────────────────────────────────────────────────
function setupEvents(){
  const cv=document.getElementById('stock-canvas'),tt=document.getElementById('chart-tooltip'),ob=document.getElementById('ohlc-bar');
  cv.addEventListener('mousemove',e=>{
    if(!OHLCV.length)return;
    const r=cv.getBoundingClientRect(),mx=e.clientX-r.left,W=cv.width,n=ve-vs;
    const i=Math.round((mx-PAD.l)/(W-PAD.l-PAD.r)*(n-1));
    const idx=Math.max(0,Math.min(n-1,i)),d=OHLCV[vs+idx];
    if(!d){tt.style.display='none';return;}
    const isU=d.close>=d.open,pct=((d.close-d.open)/d.open*100).toFixed(2),clss=isU?'tt-up':'tt-dn';
    const rsi=OHLCV._rsi?.[vs+idx],ma9v=OHLCV._ma9?.[vs+idx],ma21v=OHLCV._ma21?.[vs+idx];
    ob.innerHTML=`<span style="color:var(--muted)">O</span> <b style="color:var(--text)">${d.open.toFixed(2)}</b> &nbsp;<span style="color:var(--muted)">H</span> <b style="color:var(--success)">${d.high.toFixed(2)}</b> &nbsp;<span style="color:var(--muted)">L</span> <b style="color:var(--danger)">${d.low.toFixed(2)}</b> &nbsp;<span style="color:var(--muted)">C</span> <b class="${clss}">${d.close.toFixed(2)}</b> <b class="${clss}">${isU?'+':''}${pct}%</b>`;
    tt.innerHTML=`<div class="tt-date">${d.date.toLocaleDateString('en-US',{weekday:'short',month:'short',day:'numeric',year:'numeric'})}</div>
      <div class="tt-row"><span class="tt-key">Open</span><span class="tt-val ${clss}">${d.open.toFixed(2)}</span></div>
      <div class="tt-row"><span class="tt-key">High</span><span class="tt-val tt-up">${d.high.toFixed(2)}</span></div>
      <div class="tt-row"><span class="tt-key">Low</span><span class="tt-val tt-dn">${d.low.toFixed(2)}</span></div>
      <div class="tt-row"><span class="tt-key">Close</span><span class="tt-val ${clss}">${d.close.toFixed(2)}</span></div>
      <div class="tt-row"><span class="tt-key">Vol</span><span class="tt-val">${(d.volume/1000).toFixed(0)}K</span></div>
      ${ma9v!=null?`<div class="tt-row"><span class="tt-key" style="color:#00e5ff">MA9</span><span class="tt-val" style="color:#00e5ff">${ma9v.toFixed(2)}</span></div>`:''}
      ${ma21v!=null?`<div class="tt-row"><span class="tt-key" style="color:#f5c842">MA21</span><span class="tt-val" style="color:#f5c842">${ma21v.toFixed(2)}</span></div>`:''}
      ${rsi!=null?`<div class="tt-row"><span class="tt-key" style="color:#c77dff">RSI</span><span class="tt-val" style="color:#c77dff">${rsi.toFixed(1)}</span></div>`:''}`;
    tt.style.display='block';
    let lx=mx+14,ty=e.clientY-r.top-10;
    if(lx+175>W)lx=mx-190;if(ty+220>cv.height)ty=cv.height-230;
    tt.style.left=lx+'px';tt.style.top=ty+'px';
    // Crosshair
    renderChart();
    const x2=xS(idx,n,W);
    const ctx2=cv.getContext('2d');
    ctx2.save();ctx2.strokeStyle='rgba(0,229,255,.25)';ctx2.lineWidth=1;ctx2.setLineDash([4,4]);
    ctx2.beginPath();ctx2.moveTo(x2,PAD.t);ctx2.lineTo(x2,cv.height-PAD.b);ctx2.stroke();ctx2.setLineDash([]);ctx2.restore();
    if(dragging){const dx=Math.round((e.clientX-dragX)/(W/(ve-vs)));let ns=dragVS-dx,sp=ve-vs;ns=Math.max(0,Math.min(OHLCV.length-sp,ns));vs=ns;ve=ns+sp;renderChart();}
  });
  cv.addEventListener('mouseleave',()=>{tt.style.display='none';ob.innerHTML='';renderChart();});
  cv.addEventListener('mousedown',e=>{dragging=true;dragX=e.clientX;dragVS=vs;cv.style.cursor='grabbing';});
  window.addEventListener('mouseup',()=>{dragging=false;document.getElementById('stock-canvas').style.cursor='crosshair';});
  cv.addEventListener('wheel',e=>{e.preventDefault();zoomDelta(e.deltaY>0?1:-1);},{passive:false});
}

function zoomDelta(dir){
  const sp=ve-vs,ctr=Math.floor((vs+ve)/2);
  const ns=Math.max(20,Math.min(OHLCV.length,sp+dir*Math.ceil(sp*.12)));
  vs=Math.max(0,ctr-Math.floor(ns/2));ve=Math.min(OHLCV.length,vs+ns);
  if(ve===OHLCV.length)vs=Math.max(0,ve-ns);
  renderChart();
}
function zoomIn(){zoomDelta(-1);}
function zoomOut(){zoomDelta(1);}
function resetZoom(){vs=0;ve=Math.min(140,OHLCV.length);renderChart();}
function toggle(key){
  ind[key]=!ind[key];
  document.getElementById('tog-'+key).classList.toggle('on',ind[key]);
  resizeAll();renderChart();
}

// ── EQUITY CHART ─────────────────────────────────────────────────────────
function setEQ(type){drawEQ(type);}
function drawEQ(type){
  if(!window.Chart)return;
  const ctx=document.getElementById('eq-chart').getContext('2d');
  if(eqChart)eqChart.destroy();
  let data,label,color,fill;
  if(type==='equity'){data=eqData;label='Equity';color='#00e5ff';fill=true;}
  else if(type==='drawdown'){data=ddData;label='Drawdown %';color='#ff4560';fill=true;}
  else{data=moData;label='Monthly %';color='#00e396';fill=false;}
  const step=Math.ceil(data.length/22),th=data.filter((_,i)=>i%step===0);
  const g=ctx.createLinearGradient(0,0,0,180);g.addColorStop(0,color+'44');g.addColorStop(1,color+'00');
  eqChart=new Chart(ctx,{
    type:type==='monthly'?'bar':'line',
    data:{labels:th.map(d=>d.x),datasets:[{label,data:th.map(d=>d.y),borderColor:color,backgroundColor:type==='monthly'?th.map(d=>d.y>=0?'#00e39666':'#ff456066'):g,fill,tension:.4,pointRadius:0,borderWidth:1.5}]},
    options:{responsive:true,maintainAspectRatio:false,interaction:{intersect:false,mode:'index'},
      plugins:{legend:{display:false},tooltip:{backgroundColor:'#111820',borderColor:'#1e2d3d',borderWidth:1,titleColor:'#4a6b82',bodyColor:'#e8f4f8',titleFont:{family:'JetBrains Mono',size:9},bodyFont:{family:'JetBrains Mono',size:11,weight:'600'},callbacks:{label:c=>type==='equity'?` $${c.raw.toLocaleString()}`:` ${c.raw.toFixed(2)}%`}}},
      scales:{x:{grid:{color:'#1e2d3d'},ticks:{color:'#4a6b82',font:{family:'JetBrains Mono',size:8},maxRotation:0}},y:{grid:{color:'#1e2d3d'},ticks:{color:'#4a6b82',font:{family:'JetBrains Mono',size:8},callback:v=>type==='equity'?'$'+(v/1000).toFixed(0)+'k':v.toFixed(1)+'%'}}}}
  });
}

// ── TRADE TABLE ───────────────────────────────────────────────────────────
function buildTable(){
  const tb=document.getElementById('trade-tbody');
  document.getElementById('trade-count').textContent=`${TRADES.length} trades`;
  tb.innerHTML='';
  TRADES.forEach((t,idx)=>{
    const w=t.pnl>=0,row=document.createElement('tr');
    row.innerHTML=`<td style="color:var(--muted)">${idx+1}</td>
      <td><span class="badge badge-${t.mt}">${t.mkt}</span></td>
      <td><span class="badge badge-${t.dir}">${t.dir.toUpperCase()}</span></td>
      <td>${fmtD(t.ed)}</td><td>${fmtD(t.xd)}</td>
      <td>$${t.ep.toFixed(2)}</td><td>$${t.xp.toFixed(2)}</td>
      <td>$${Math.round(t.sz).toLocaleString()}</td>
      <td class="${w?'ppos':'pneg'}">${w?'+':''}$${Math.abs(t.pnl).toFixed(2)}</td>
      <td class="${w?'ppos':'pneg'}">${w?'+':''}${t.pct.toFixed(2)}%</td>
      <td style="color:var(--muted)">${Math.floor(Math.random()*36+2)}h</td>`;
    row.addEventListener('click',()=>{
      document.querySelectorAll('#trade-tbody tr').forEach(r=>r.classList.remove('sel'));
      row.classList.add('sel');hlTrade=t;
      const sp=ve-vs;let ns=Math.max(0,t.ei-Math.floor(sp/2));vs=ns;ve=Math.min(OHLCV.length,ns+sp);
      renderChart();document.getElementById('chart-con').scrollIntoView({behavior:'smooth',block:'center'});
    });
    tb.appendChild(row);
  });
}

// ── UTILS ─────────────────────────────────────────────────────────────────
function fmtD(d){return d.toLocaleDateString('en-US',{month:'short',day:'numeric',year:'2-digit'});}


// ── LIVE MARKET DATA (CoinGecko free API) ────────────────────────────────
const LIVE_ASSETS = [
  {id:'bitcoin',sym:'BTC/USD',type:'crypto',name:'Bitcoin'},
  {id:'ethereum',sym:'ETH/USD',type:'crypto',name:'Ethereum'},
  {id:'solana',sym:'SOL/USD',type:'crypto',name:'Solana'},
  {id:'binancecoin',sym:'BNB/USD',type:'crypto',name:'BNB'},
  {id:'ripple',sym:'XRP/USD',type:'crypto',name:'Ripple'},
  {id:'cardano',sym:'ADA/USD',type:'crypto',name:'Cardano'},
  {id:'dogecoin',sym:'DOGE/USD',type:'crypto',name:'Dogecoin'},
  {id:'avalanche-2',sym:'AVAX/USD',type:'crypto',name:'Avalanche'},
];

let liveCache = {};

async function fetchLivePrices() {
  try {
    const ids = LIVE_ASSETS.map(a=>a.id).join(',');
    const url = `https://api.coingecko.com/api/v3/simple/price?ids=${ids}&vs_currencies=usd&include_24hr_change=true&include_24hr_vol=true&include_high_24h=true&include_low_24h=true`;
    const res = await fetch(url);
    if (!res.ok) throw new Error('API error');
    const data = await res.json();
    liveCache = data;
    updateHeroPrices(data);
    updateMarketTable(data);
    updateTickerWithLive(data);
  } catch(e) {
    console.warn('Live price fetch failed, using fallback data');
    useFallbackPrices();
  }
}

function fmt$(v) {
  if (!v && v !== 0) return '—';
  if (v >= 1000) return '$' + v.toLocaleString('en-US', {maximumFractionDigits:2});
  if (v >= 1) return '$' + v.toFixed(2);
  return '$' + v.toFixed(4);
}
function fmtVol(v) {
  if (!v) return '—';
  if (v >= 1e9) return '$' + (v/1e9).toFixed(2) + 'B';
  if (v >= 1e6) return '$' + (v/1e6).toFixed(1) + 'M';
  return '$' + (v/1e3).toFixed(0) + 'K';
}

function updateHeroPrices(data) {
  const map = {
    'lp-btc': data.bitcoin,
    'lp-eth': data.ethereum,
    'lp-sol': data.solana,
    'lp-bnb': data.binancecoin,
  };
  Object.entries(map).forEach(([id, d]) => {
    if (!d) return;
    const el = document.getElementById(id);
    const chEl = document.getElementById(id + '-c');
    if (el) el.textContent = fmt$(d.usd);
    if (chEl) {
      const chg = d.usd_24h_change;
      chEl.textContent = (chg >= 0 ? '+' : '') + chg.toFixed(2) + '%';
      chEl.className = 'lp-pc-chg ' + (chg >= 0 ? 'up' : 'dn');
    }
  });
}

function updateMarketTable(data) {
  const tbody = document.getElementById('market-table-body');
  if (!tbody) return;
  tbody.innerHTML = '';
  LIVE_ASSETS.forEach(asset => {
    const d = data[asset.id];
    if (!d) return;
    const chg = d.usd_24h_change || 0;
    const isUp = chg >= 0;
    const hi = d.usd_24h_high || d.usd;
    const lo = d.usd_24h_low || d.usd;
    const rangePct = hi > lo ? ((d.usd - lo) / (hi - lo) * 100).toFixed(0) : 50;
    const vol = d.usd_24h_vol;
    tbody.innerHTML += `
      <tr>
        <td><div class="mt-sym">${asset.sym}</div><div class="mt-name">${asset.name}</div></td>
        <td><span class="mt-type-badge ${asset.type}">${asset.type}</span></td>
        <td class="mt-price">${fmt$(d.usd)}</td>
        <td class="mt-chg ${isUp?'up':'dn'}">${isUp?'+':''}${chg.toFixed(2)}%</td>
        <td style="color:var(--success);font-size:.72rem">${fmt$(hi)}</td>
        <td style="color:var(--danger);font-size:.72rem">${fmt$(lo)}</td>
        <td>
          <div style="display:flex;align-items:center;gap:.6rem">
            <span style="font-size:.68rem;color:var(--muted)">${fmtVol(vol)}</span>
            <div class="mt-bar-wrap"><div class="mt-bar ${isUp?'up':'dn'}" style="width:${rangePct}%"></div></div>
          </div>
        </td>
      </tr>`;
  });
}

function updateTickerWithLive(data) {
  const tickerEl = document.getElementById('ticker');
  if (!tickerEl || !Object.keys(data).length) return;
  const items = LIVE_ASSETS.map(a => {
    const d = data[a.id];
    if (!d) return '';
    const chg = d.usd_24h_change || 0;
    const isUp = chg >= 0;
    return `<span class="ticker-item"><span class="ticker-sym">${a.sym}</span><span class="ticker-price">${fmt$(d.usd)}</span><span class="ticker-chg ${isUp?'up':'dn'}">${isUp?'+':''}${chg.toFixed(2)}%</span></span>`;
  }).filter(Boolean);
  const doubled = [...items,...items].join('');
  tickerEl.innerHTML = doubled;
}

function useFallbackPrices() {
  // Static fallback if API fails
  const fallback = {
    bitcoin:{usd:67421,usd_24h_change:2.34,usd_24h_high:68900,usd_24h_low:65800,usd_24h_vol:28e9},
    ethereum:{usd:3812,usd_24h_change:1.87,usd_24h_high:3900,usd_24h_low:3700,usd_24h_vol:14e9},
    solana:{usd:189,usd_24h_change:-0.62,usd_24h_high:195,usd_24h_low:185,usd_24h_vol:3e9},
    binancecoin:{usd:612,usd_24h_change:3.11,usd_24h_high:625,usd_24h_low:598,usd_24h_vol:2e9},
    ripple:{usd:0.62,usd_24h_change:1.2,usd_24h_high:0.65,usd_24h_low:0.60,usd_24h_vol:1.5e9},
    cardano:{usd:0.45,usd_24h_change:-1.1,usd_24h_high:0.47,usd_24h_low:0.43,usd_24h_vol:0.8e9},
    dogecoin:{usd:0.18,usd_24h_change:4.2,usd_24h_high:0.19,usd_24h_low:0.17,usd_24h_vol:1.1e9},
    'avalanche-2':{usd:38,usd_24h_change:-0.8,usd_24h_high:39.5,usd_24h_low:37.2,usd_24h_vol:0.6e9},
  };
  liveCache = fallback;
  updateHeroPrices(fallback);
  updateMarketTable(fallback);
  updateTickerWithLive(fallback);
}

// Fetch immediately, then every 30 seconds
fetchLivePrices();
setInterval(fetchLivePrices, 30000);

