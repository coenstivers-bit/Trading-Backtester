<script>
// ── TICKER ──────────────────────────────────────────────────────────────
const TD=[
  {sym:'BTC/USD',price:'$67,421',chg:'+2.34%',up:true},{sym:'ETH/USD',price:'$3,812',chg:'+1.87%',up:true},
  {sym:'SOL/USD',price:'$189.4',chg:'-0.62%',up:false},{sym:'SPX',price:'5,418',chg:'+0.43%',up:true},
  {sym:'NQ100',price:'19,204',chg:'+0.71%',up:true},{sym:'ES1!',price:'5,402',chg:'+0.38%',up:true},
  {sym:'GC1!',price:'$2,341',chg:'-0.21%',up:false},{sym:'CL1!',price:'$83.12',chg:'+1.05%',up:true},
  {sym:'DAX',price:'18,762',chg:'+0.55%',up:true},{sym:'VIX',price:'14.22',chg:'-3.20%',up:false},
];
const tEl=document.getElementById('ticker');
tEl.innerHTML=[...TD,...TD].map(d=>`<span class="ticker-item"><span class="ticker-sym">${d.sym}</span><span class="ticker-price">${d.price}</span><span class="ticker-chg ${d.up?'up':'dn'}">${d.chg}</span></span>`).join('');

// ── TABS & CHIPS ─────────────────────────────────────────────────────────
document.getElementById('setup-tabs').addEventListener('click',e=>{
  const tab=e.target.closest('.tab');if(!tab)return;
  document.querySelectorAll('#setup-tabs .tab').forEach(t=>t.classList.remove('active'));
